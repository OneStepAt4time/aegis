{
  "defaultSessionEnv": {
    "ANTHROPIC_BASE_URL": "${AZURE_OPENAI_BASE_URL:-https://YOUR-RESOURCE.openai.azure.com/openai/v1}",
    "ANTHROPIC_AUTH_TOKEN": "${AZURE_OPENAI_API_KEY}",
    "ANTHROPIC_DEFAULT_MODEL": "${AZURE_OPENAI_DEPLOYMENT:-gpt-4o-mini}",
    "ANTHROPIC_DEFAULT_FAST_MODEL": "${AZURE_OPENAI_FAST_DEPLOYMENT:-gpt-4o-mini}",
    "API_TIMEOUT_MS": "${AZURE_OPENAI_TIMEOUT_MS:-60000}"
  }
}
