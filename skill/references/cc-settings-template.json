{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "plansDirectory": ".claude/plans",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(tsc --noEmit *)",
      "Bash(vitest *)",
      "Read",
      "Edit",
      "Write",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf /home/*)",
      "Bash(git push * --force)",
      "Bash(git push * main)",
      "Bash(git push --no-verify *)",
      "Read(./.env)",
      "Read(./.env.*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "attribution": {
    "commit": "Generated by [Aegis/Hephaestus]",
    "pr": "Generated by [Aegis/Hephaestus]"
  }
}
