{
  "name": "@onestepat4time/aegis-client",
  "version": "0.4.0",
  "type": "module",
  "description": "Official TypeScript client for Aegis. Generated from OpenAPI 3.1 specification. Covers all 53 REST endpoints.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/generated"
  ],
  "scripts": {
    "build": "tsc",
    "generate": "openapi-ts --input ../openapi.yaml --output src/generated",
    "clean": "rm -rf dist src/generated"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OneStepAt4time/aegis.git",
    "directory": "packages/client"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "aegis",
    "claude-code",
    "orchestration",
    "mcp",
    "api-client",
    "openapi",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.96.1",
    "typescript": "^5.7.0"
  }
}
